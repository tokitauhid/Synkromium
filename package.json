{
  "name": "synkromium",
  "version": "0.1.5",
  "description": "Keep your Chromium browser settings and extensions in sync across all your devices, privately and automatically.",
  "type": "module",
  "main": "dist/main.js",
  "homepage": "https://github.com/tokitauhid/Synkromium",
  "repository": {
    "type": "git",
    "url": "https://github.com/tokitauhid/Synkromium.git"
  },
  "scripts": {
    "build:main": "tsc",
    "build:renderer": "tsc -p src/ui/renderer/tsconfig.json",
    "build:preload": "esbuild src/preload.ts --bundle --platform=node --external:electron --outfile=dist/preload.js",
    "copy:assets": "node scripts/copy-assets.js",
    "build": "npm run build:main && npm run build:renderer && npm run build:preload && npm run copy:assets",
    "dev": "npm run build && electron dist/main.js",
    "start": "electron dist/main.js",
    "dist": "npm run build && electron-builder -p never",
    "dist:linux": "npm run build && electron-builder --linux -p never",
    "dist:mac": "npm run build && electron-builder --mac -p never",
    "dist:win": "npm run build && electron-builder --win -p never",
    "install:linux": "bash install.sh",
    "version": "node scripts/update-version.js && git add README.md src/ui/renderer/index.html src/config/constants.ts",
    "release": "node scripts/release.js"
  },
  "author": "Tokit Auhid <tokitauhidmim12@gmail.com>",
  "license": "MIT",
  "keywords": [
    "chromium",
    "sync",
    "browser",
    "settings",
    "extensions",
    "git"
  ],
  "build": {
    "appId": "com.synkromium.app",
    "productName": "Synkromium",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "icon": "build/icons/icon.png",
      "category": "Utility",
      "synopsis": "Private, Git-backed Chromium browser sync"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icons/icon.png",
      "darkModeSupport": true,
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "tokitauhid",
      "repo": "Synkromium"
    }
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "chokidar": "^5.0.0"
  }
}
