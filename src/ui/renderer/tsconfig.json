{
  "compilerOptions": {
    // The renderer runs in a browser context inside Electron,
    // so it needs DOM types (document, window, etc.) instead of Node types.
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "DOM"],

    "outDir": "../../dist/ui/renderer",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "sourceMap": true,
    "noEmitOnError": true,
    "skipLibCheck": true
  },
  "include": ["./**/*"]
}
